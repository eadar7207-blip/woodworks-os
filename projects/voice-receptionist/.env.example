# AI Voice Receptionist - Environment Configuration

# ========== LLM & APIs ==========
# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-your-api-key-here

# ElevenLabs (TTS - text to speech)
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ========== Phone & Voice ==========
# Twilio (inbound calls)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ========== Automation Framework Integration ==========
# Connect to Eitan's automation framework
SKILL_BRIDGE_URL=http://localhost:9000
EXECUTOR_URL=http://localhost:5000
AUTOMATION_API_KEY=your-shared-secret-key

# ========== Database ==========
DATABASE_URL=sqlite:///voice_receptionist.db

# ========== Server ==========
PORT=5001
DEBUG=False
LOG_LEVEL=INFO

# ========== Application ==========
APP_ENV=development
ENVIRONMENT=development
