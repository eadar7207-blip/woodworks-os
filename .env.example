# Copy this file to .env and fill in your values
# Never commit .env to git

# YouTube Data API v3
# Get free at: console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
# Free quota: 10,000 units/day (weekly report uses ~500)
YOUTUBE_API_KEY=

# OpenAI
OPENAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Make (formerly Integromat)
MAKE_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# Gmail / Google (OAuth credentials stored in credentials.json and token.json)
# No key needed here -- handled via OAuth flow

# Twilio (if used for voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Zapier
ZAPIER_WEBHOOK_URL=
